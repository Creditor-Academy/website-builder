{
    "name": "website-builder-root",
    "private": true,
    "scripts": {
        "dev": "npm run dev --prefix frontend",
        "dev:backend": "npm run dev --prefix backend",
        "build": "npm run build:backend && npm run build:frontend",
        "build:backend": "npm run build --prefix backend",
        "build:frontend": "npm run build --prefix frontend",
        "start:backend": "npm run start --prefix backend",
        "preview": "npm run preview --prefix frontend",
        "lint": "npm run lint --prefix frontend",
        "lint:backend": "npx --prefix backend tsc --noEmit",
        "test": "npm run test:backend && npm run test:frontend",
        "test:backend": "npm test --prefix backend",
        "test:frontend": "npm test --prefix frontend",
        "typecheck": "npm run lint:backend && npx --prefix frontend tsc --noEmit"
    }
}