# ─── Required ─────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
POSTGRESQL_URL=postgresql://user:password@localhost:5432/buildora

# ─── Redis (Upstash) ─────────────────────────────────────────────────────────
REDIS_URL=https://your-upstash-url.upstash.io
REDIS_TOKEN=your-upstash-token

# ─── S3 / MinIO ──────────────────────────────────────────────────────────────
S3_BUCKET=buildora-assets
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9000/buildora-assets

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=Buildora <noreply@buildora.app>

# ─── Optional ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
LOG_LEVEL=debug
APP_NAME=Buildora
BCRYPT_SALT_ROUNDS=12
FRONTEND_ORIGINS=http://localhost:8080,http://localhost:8081
FRONTEND_URL=http://localhost:8080
PUBLISHED_SITES_BASE_URL=http://localhost:5000/sites

# AWS S3 Configuration (for static site hosting & assets)
S3_BUCKET=buildora-assets
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-aws-access-key-id
S3_SECRET_ACCESS_KEY=your-aws-secret-access-key
S3_PUBLIC_BASE_URL=http://buildora-assets.s3-website-us-east-1.amazonaws.com

# Public site host (subdomains for published sites)
PUBLIC_SITE_HOST=buildora.app