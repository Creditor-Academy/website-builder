# Database connection strings
MONGODB_URL=mongodb://localhost:27017/dbname
POSTGRESQL_URL="postgres://............../postgres?sslmode=require"

# Redis Configuration
REDIS_URL=redis-upstash-url
REDIS_TOKEN=redis-upstash-token

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=1d

# CORS
CORS_ORIGIN=http://localhost:3000

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:8080

# Bcrypt Configuration
BCRYPT_SALT_ROUNDS=12

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# AWS S3 Credentials
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-access-key-secret"
AWS_REGION="your-aws-region"
AWS_BUCKET_NAME="your-aws-bucket-name"
AWS_ASSET_BASE_URL="https://your-aws-bucket-name.s3.your-aws-region.amazonaws.com"