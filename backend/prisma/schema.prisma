generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                   @id @default(cuid())
  name                    String
  email                   String                   @unique
  password_hash           String?
  auth_provider           String                   @default("email")
  role                    UserRole                 @default(USER)
  institution_id          String?
  isActive                Boolean                  @default(true)
  isVerified              Boolean                  @default(false)
  lastLoginAt             DateTime?
  lastPasswordChangeAt    DateTime?
  created_at              DateTime                 @default(now())
  updated_at              DateTime                 @updatedAt
  deleted_at              DateTime?
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  refreshTokens           RefreshToken[]
  institution             Institution?             @relation(fields: [institution_id], references: [id])
  ownedWebsites           Website[]                @relation("WebsiteOwner")

  @@index([email])
  @@index([auth_provider])
  @@index([deleted_at])
  @@map("users")
}

model Institution {
  id         String    @id @default(cuid())
  name       String
  email      String    @unique
  status     String    @default("PENDING")
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  users      User[]
  websites   Website[]
  templates  WebsiteTemplate[]
  sectionTemplates SectionTemplate[]

  @@map("institutions")
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  token_hash String   @unique
  expiresAt  DateTime
  isUsed     Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token_hash])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id         String   @id @default(cuid())
  userId     String
  token_hash String   @unique
  expiresAt  DateTime
  created_at DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token_hash])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  token_hash String   @unique
  sessionId  String
  expiresAt  DateTime
  isRevoked  Boolean  @default(false)
  replacedBy String?
  created_at DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token_hash])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Website {
  id                        String        @id @default(cuid())
  name                      String
  owner_id                  String
  source_template_id        String?
  status                    WebsiteStatus @default(DRAFT)
  thumbnail_url             String?
  currentDraftVersionId     String?
  currentPublishedVersionId String?
  created_at                DateTime      @default(now())
  updated_at                DateTime      @updatedAt
  deleted_at                DateTime?
  institution_id            String?
  content                   Json?
  settings_id               String?       @unique
  institution               Institution?  @relation(fields: [institution_id], references: [id])
  owner                     User          @relation("WebsiteOwner", fields: [owner_id], references: [id], onDelete: Cascade)
  sourceTemplate            WebsiteTemplate? @relation(fields: [source_template_id], references: [id], onDelete: SetNull)
  settings                  Settings?     @relation(fields: [settings_id], references: [id], onDelete: Cascade)

  @@index([owner_id])
  @@index([source_template_id])
  @@index([status])
  @@index([deleted_at])
  @@map("websites")
}

model Settings {
  id           String   @id @default(cuid())
  seo          Json?
  contact      Json?
  social_links Json?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  website      Website?

  @@map("settings")
}

enum UserRole {
  USER
  ADMIN
  STUDENT
  INSTRUCTOR
  INSTITUTION_ADMIN
  SUPER_ADMIN
}

enum WebsiteStatus {
  DRAFT
  PUBLISHED
  DELETED
}

enum TemplateScope {
  GLOBAL
  INSTITUTION
}


model WebsiteTemplate {
  id            String    @id @default(cuid())
  name          String
  description   String
  category      String
  scope         TemplateScope @default(GLOBAL)
  institution_id String?
  image         String?
  global_styles Json      @default("{}")
  navbar        Json      @default("{}")
  footer        Json      @default("{}")
  home_layout   Json      @default("{}")
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  institution   Institution? @relation(fields: [institution_id], references: [id], onDelete: SetNull)
  websites      Website[]

  @@index([scope])
  @@index([institution_id])
}

model SectionTemplate {
  id             String         @id @default(cuid())
  name           String
  category       String
  scope          TemplateScope  @default(GLOBAL)
  institution_id String?
  props          Json           @default("{}")
  deletedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  institution    Institution?   @relation(fields: [institution_id], references: [id], onDelete: SetNull)

  @@index([scope])
  @@index([institution_id])
}